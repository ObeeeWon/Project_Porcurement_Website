{
  "name": "arps-procurement",
  "version": "1.0.0",
  "description": "Applied Research Procurement System (ARPS) - Cloudflare Pages + Functions + D1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler pages dev public",
    "db:init:local": "wrangler d1 execute procurement_db --local --file=migrations/0001_init.sql",
    "db:init:remote": "wrangler d1 execute procurement_db --remote --file=migrations/0001_init.sql",
    "deploy": "wrangler pages deploy public --project-name=procurement --commit-dirty=true",
    "dns:setup": "node scripts/setup-dns.mjs"
  },
  "devDependencies": {
    "wrangler": "^4.96.0"
  }
}
